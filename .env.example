# ============================================================
# Discord CC Bot - environment configuration
# Copy this file to ".env" and fill in your own values.
# (Lines starting with "#" are comments.)
# ============================================================

# [Required] Your Discord bot token.
# Create an application at https://discord.com/developers/applications
# then open the "Bot" tab -> Reset Token -> Copy.
DISCORD_TOKEN=

# [Required] The Discord channel ID the bot listens to (its main channel).
# First enable Developer Mode: Discord Settings -> Advanced -> Developer Mode.
# Then right-click the channel -> Copy Channel ID.
ALLOWED_CHANNEL=

# [Required] Your Discord user ID (the bot owner; only this user may control it).
# Right-click your own name -> Copy User ID (Developer Mode must be on).
ALLOWED_USER=

# [Optional] Interface language: "en" (default) or "zh-TW".
# Controls both the bot's own UI text AND the language Claude is asked to reply in.
BOT_LANG=en

# [Optional] Channel ID for posting version-update announcements.
# Leave empty to disable update announcements.
UPDATE_CHANNEL=

# [Optional] Path to the Claude Code CLI executable.
# Defaults to %APPDATA%\npm\claude.cmd (the usual npm global install on Windows).
# Only set this if your claude.cmd lives somewhere else.
CLAUDE_CLI=

# [Optional] Default working directory the bot operates in.
# Defaults to your home directory. Set an absolute path to scope the bot
# to a specific folder.
DEFAULT_DIR=

# [Optional] Default Claude model for new conversations.
# Defaults to "claude-sonnet-4-6" (standard 200K context), which works on every
# plan and needs no usage credits. Leaving this empty is recommended.
# Only set it if you specifically want a different default model. If your plan
# has 1M-context usage credits and you want the 1M window, use the 1M alias
# (e.g. "claude-sonnet-4-6[1m]") -- the auto-compaction threshold adjusts to match.
# (You can also switch models at runtime with the /model command.)
DEFAULT_MODEL=

# [Optional] Names for the multi-conversation sidebar (category + entry channel).
# Leave empty to use the defaults. If TWO bots run in the SAME Discord server,
# give each bot a DIFFERENT SIDEBAR_CATEGORY so they don't fight over the same
# category (which causes duplicate welcome messages and crossed-up channels).
SIDEBAR_CATEGORY=
SIDEBAR_ENTRY=
