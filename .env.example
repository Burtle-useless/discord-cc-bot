# ============================================================
# Discord CC Bot - environment configuration
# Copy this file to ".env" and fill in your own values.
# (Lines starting with "#" are comments.)
# ============================================================

# [Required] Your Discord bot token.
# Create an application at https://discord.com/developers/applications
# then open the "Bot" tab -> Reset Token -> Copy.
DISCORD_TOKEN=

# [Required] The Discord channel ID the bot listens to (its main channel).
# First enable Developer Mode: Discord Settings -> Advanced -> Developer Mode.
# Then right-click the channel -> Copy Channel ID.
ALLOWED_CHANNEL=

# [Required] Your Discord user ID (the bot owner; only this user may control it).
# Right-click your own name -> Copy User ID (Developer Mode must be on).
ALLOWED_USER=

# [Optional] Channel ID for posting version-update announcements.
# Leave empty to disable update announcements.
UPDATE_CHANNEL=

# [Optional] Path to the Claude Code CLI executable.
# Defaults to %APPDATA%\npm\claude.cmd (the usual npm global install on Windows).
# Only set this if your claude.cmd lives somewhere else.
CLAUDE_CLI=

# [Optional] Default working directory the bot operates in.
# Defaults to your home directory. Set an absolute path to scope the bot
# to a specific folder.
DEFAULT_DIR=
